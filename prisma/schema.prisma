generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id           String    @id @default(cuid())
  email        String?   @unique
  name         String?
  passwordHash String?
  isAdmin      Boolean   @default(false)
  onboardedAt  DateTime?
  createdAt    DateTime  @default(now())

  /// S7-T03 — non-null when the user has requested deletion. The sweep cron
  /// deletes the row (and cascades) when `pendingDeletionAt < now`.
  /// 24h grace lets the user undo.
  pendingDeletionAt DateTime?

  goals          Goal[]
  tasks          Task[]
  days           Day[]
  clicks         Click[]
  prefs          Pref?
  dailyContents  DailyContent[]
  llmCredentials LlmCredential[]
  refreshLogs    RefreshLog[]
  journalEntries JournalEntry[]
  bookmarks      Bookmark[]

  // S0-T02 additions
  journalThemes  JournalTheme[]
  suggestedGoals SuggestedGoal[]
  vouchers       Voucher[]
  rewardClaims   RewardClaim[]

  // S7-T02 — User-initiated data export. Each row is a one-shot, 24h-valid
  // download token. Cascades on user delete so we never leave dangling links.
  dataExports    DataExport[]
}

model Pref {
  id          String  @id @default(cuid())
  userId      String  @unique
  user        User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  theme       String  @default("light")  // 'light' | 'dark' (extended in Phase 11)
  filter      String  @default("all")    // 'all' | 'mindfulness' | 'business' | 'personal'
  jobTitle    String?
  interests   String?                    // JSON array of strings
  faith       String?                    // 'christian' | 'jewish' | 'muslim' | 'spiritual' | 'none' | custom
  scripturePref String?                  // 'kjv' | 'niv' | etc; null when faith is 'none'
  contentInterests String?                // JSON array of strings (LLM context)
  bio         String?
  refreshHour Int      @default(4)       // 0-23, local-time hour for daily content refresh
  bgImageUrl  String?                    // optional URL for the page background image
  bgOverlay   Int      @default(90)      // 0-100, theme color overlay opacity over the bg image

  // S0-T02 — Slow Sip + dual-run resilience
  hobbies        String?  // JSON array: ["woodworking", "japanese", "piano"]
  livesWith      String?  // JSON array: ["partner", "kids", "alone"]
  financeMode    Boolean  @default(false)
  netWorth       String?  // user-entered display string (no bank integration)
  cashOnHand     String?
  savingsTarget  String?
  prebrewHour    Int      @default(17)  // 5pm default for the safety-net evening pre-brew run
  prebrewEnabled Boolean  @default(true)
  industry       String?  // for Daily Grind curation bias
  companyStage   String?  // for Daily Grind curation bias (e.g., 'series-b')
  timezone       String?  // IANA name for cron scheduling
}

model Goal {
  id        String   @id            // 'g_god', 'g_min_<ts>'
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  section   String                  // 'mindfulness' | 'business' | 'personal'
  title     String
  type      String                  // 'check' | 'count' | 'time'
  target    Int
  isDefault Boolean  @default(false)
  createdAt DateTime @default(now())

  // S0-T02 — Slow Sip categorization. Optional. Cross-cuts section.
  // 'family' | 'finance' | 'hobby' | 'fitness' | 'faith' | 'work'
  category  String?

  @@index([userId, section])
  @@index([userId, category])
}

model Task {
  id          String   @id          // 't_<ts>'
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  title       String
  section     String                // 'general' | 'mindfulness' | 'business' | 'personal'
  done        Boolean  @default(false)
  createdAt   DateTime @default(now())
  completedOn String?               // ISO date

  @@index([userId, done])
}

model Day {
  id         String   @id @default(cuid())
  userId     String
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  iso        String                 // 'YYYY-MM-DD'
  goalsJson  String   @default("{}")   // map goalId -> boolean | number
  notes      String   @default("")
  healthJson String   @default("{}")   // { slept, moved, ate }
  disconnect Int      @default(0)
  win        String   @default("")
  finJson    String   @default("{}")   // { net, cash, invest }

  @@unique([userId, iso])
}

model Click {
  id           String   @id @default(cuid())
  userId       String
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  iso          String                  // 'YYYY-MM-DD'
  section      String                  // 'mindfulness' | 'business' | 'personal'
  count        Int      @default(0)

  @@unique([userId, iso, section])
}

model DailyContent {
  id          String   @id @default(cuid())
  userId      String
  iso         String   // 'YYYY-MM-DD'
  contentJson String   // serialized DailyContent JSON; validated at the boundary
  source      String   // 'manual' | 'llm' | 'fixture'
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // S0-T02 — Dual-run resilience. The 5pm pre-brew on Day N writes
  // to backupContentJson on the Day N+1 row. Morning brew writes
  // to contentJson. Read-time precedence: contentJson → backup → fixture.
  backupContentJson String?
  primarySource     String?    // 'manual' | 'morning' | 'cold-start' (which run wrote contentJson)
  backupSource      String?    // 'evening-prebrew' | 'manual-prebrew'
  primaryAt         DateTime?
  backupAt          DateTime?

  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, iso])
  @@index([userId, iso])
}

model LlmCredential {
  id           String   @id @default(cuid())
  userId       String
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  provider     String   // 'openai' | 'anthropic' | 'lmstudio'
  encryptedKey String   // base64( iv | ciphertext | tag )
  last4        String   // last 4 chars of plaintext key (UI display)
  model        String   // user-selected model id
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@unique([userId, provider])
  @@index([userId])
}

model JournalEntry {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  iso       String                 // 'YYYY-MM-DD' — the day this entry belongs to
  page      String                 // 'mindfulness' | 'business' | 'personal' | 'overview'
  content   String
  createdAt DateTime @default(now())

  @@index([userId, iso])
  @@index([userId, iso, page])
}

model Bookmark {
  id           String    @id @default(cuid())
  userId       String
  user         User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  url          String
  title        String
  source       String?               // 'mindfulness' | 'business' | 'personal' | 'top' | etc.
  excerpt      String?
  isBookmarked Boolean   @default(false)  // explicit user bookmark vs share-only row
  pinned       Boolean   @default(false)
  pinnedAt     DateTime?
  sortOrder    Int       @default(0)      // user-assigned order in Bookmarked section
  shareCount   Int       @default(0)
  lastSharedAt DateTime?
  createdAt    DateTime  @default(now())

  @@unique([userId, url])
  @@index([userId, createdAt])
  @@index([userId, lastSharedAt])
  @@index([userId, shareCount])
}

model RefreshLog {
  id          String    @id @default(cuid())
  userId      String
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  iso         String    // YYYY-MM-DD — the day of the content being generated
  source      String    // 'manual' | 'cron' | 'cold-start'
  status      String    // 'ok' | 'rate-limited' | 'no-credential' | 'provider-error' | 'validation-error'
  tokensUsed  Int       @default(0)
  errorCode   String?
  errorDetail String?
  startedAt   DateTime  @default(now())
  finishedAt  DateTime?

  // S0-T02 — Dual-run phase tag. Identifies WHICH cron-triggered run a
  // log row belongs to so admins can compute morning vs. pre-brew success rates.
  phase       String?   // 'morning' | 'evening-prebrew' | 'cold-start' | 'manual'

  @@index([userId, iso])
  @@index([userId, startedAt])
  @@index([phase, status, startedAt])
}

// S0-T02 — Journal Listens (Phase C). Theme tokens extracted from journal
// entries, recency-weighted. The LLM prompt reads top unmuted themes by
// weight to bias tomorrow's content. Theme strings are short tokens
// ("presence", "rest"); never user verbatim.
model JournalTheme {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  theme     String
  weight    Float    @default(1)
  muted     Boolean  @default(false)  // user can mute themes from biasing content
  lastSeen  DateTime @default(now())

  @@unique([userId, theme])
  @@index([userId, weight])
}

// S0-T02 — Suggested goals derived from journal intent phrases ("I want to…").
// User accepts to create a real Goal, or dismisses.
model SuggestedGoal {
  id              String   @id @default(cuid())
  userId          String
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  title           String
  cadence         String   // 'daily' | 'weekly'
  category        String?
  sourceJournalId String?  // FK back to JournalEntry that triggered it
  status          String   @default("pending")  // 'pending' | 'accepted' | 'dismissed'
  createdAt       DateTime @default(now())

  @@index([userId, status])
}

// S0-T02 — Coffee partnerships (Phase D). Indie roasters + chains (Caribou,
// Scooter's, Starbucks). Vouchers issued from a per-partner weekly pool.
model Partner {
  id           String   @id @default(cuid())
  name         String
  slug         String   @unique
  type         String   // 'chain' | 'indie'
  city         String?  // for indie roasters; null for chains (national)
  state        String?
  logoUrl      String?
  blurb        String?  // editorial copy for the partner card
  active       Boolean  @default(true)
  weeklyBudget Int      @default(0)  // # of vouchers to seed per week
  createdAt    DateTime @default(now())

  vouchers Voucher[]
}

model Voucher {
  id         String    @id @default(cuid())
  partnerId  String
  partner    Partner   @relation(fields: [partnerId], references: [id], onDelete: Cascade)
  code       String    @unique  // single-use redeem code
  issued     Boolean   @default(false)  // false = available in pool; true = assigned to user
  redeemedAt DateTime?
  userId     String?
  user       User?     @relation(fields: [userId], references: [id], onDelete: SetNull)
  expiresAt  DateTime
  weekOf     DateTime  // start of the calendar week this voucher belongs to

  rewardClaim RewardClaim?

  @@index([partnerId, issued, expiresAt])
}

model RewardClaim {
  id           String   @id @default(cuid())
  userId       String
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  voucherId    String   @unique
  voucher      Voucher  @relation(fields: [voucherId], references: [id])
  streakLength Int      // 7, 14, 21, etc.
  claimedAt    DateTime @default(now())

  @@index([userId, claimedAt])
}

// S7-T02 — User-initiated data export. Click "Email my export" → server emails
// a tokenized link that expires 24h later. The download is one-shot
// (`completedAt` is set on first GET and the link 410s afterward).
model DataExport {
  id          String    @id @default(cuid())
  userId      String
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  token       String    @unique
  /// When the link expires (24h from request).
  expiresAt   DateTime
  /// When the user actually downloaded (or null). One-shot — set on first GET.
  completedAt DateTime?
  createdAt   DateTime  @default(now())

  @@index([userId, createdAt])
  @@index([token])
}
