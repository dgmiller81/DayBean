# Deploy target: 'local' or 'railway'. Boot guard refuses unsafe combos with AUTH_MODE.
DEPLOY_TARGET="local"

# DB (Phase 1 = sqlite). Phase 13 swaps to postgres for railway target.
DATABASE_URL="file:./dev.db"

# 32-byte base64 key — generate with: openssl rand -base64 32
APP_ENCRYPTION_KEY="REPLACE_WITH_32_BYTE_BASE64_KEY"

# Auth: 'none' | 'simple' | 'full'. Phase 1 uses 'none'. Phase 7 enables the others.
AUTH_MODE="none"

# Required when AUTH_MODE=simple or AUTH_MODE=full. Generate: openssl rand -base64 32
AUTH_SECRET=""

# Required when AUTH_MODE=simple. Generate: pnpm exec tsx scripts/hash-password.ts
SIMPLE_PASSWORD_HASH=""

# Phase 10 scheduler. Required on railway.
CRON_SECRET=""

# Optional: LLM .env override.
# When LLM_DEFAULT is set, the matching API key REPLACES any per-user
# LlmCredential row. Use this for self-hosted single-user installs to
# skip the Settings UI entirely.
#   LLM_DEFAULT  ::= "OpenAI" | "Anthropic" | "LM Studio"  (case-insensitive)
#   MODEL_DEFAULT::= e.g. "gpt-4o", "claude-sonnet-4-5"
LLM_DEFAULT=""
MODEL_DEFAULT=""

OPENAI_API_KEY=""
ANTHROPIC_API_KEY=""

# Optional: override LM Studio URL (default http://localhost:1234/v1)
LMSTUDIO_BASE_URL=""

# Optional: GitHub personal access token. Raises GitHub Search rate limit
# from 10/min unauthenticated to 30/min. No scopes needed — read-only.
# Generate at https://github.com/settings/tokens (classic, no scopes)
# or https://github.com/settings/personal-access-tokens (fine-grained).
GITHUB_TOKEN=""
