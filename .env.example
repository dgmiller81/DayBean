# Deploy target: 'local' or 'railway'. Boot guard refuses unsafe combos with AUTH_MODE.
DEPLOY_TARGET="local"

# DB. Postgres on both local dev and Railway prod (single provider for parity).
# Local dev: easiest is `docker run -d --name daybeans-pg -p 5432:5432 -e POSTGRES_PASSWORD=local postgres:16`
# then DATABASE_URL="postgresql://postgres:local@localhost:5432/daybeans"
# (run `npx prisma migrate dev` once to apply the init migration to your local DB).
# On Railway: set DATABASE_URL="${{Postgres.DATABASE_URL}}" — Railway resolves the
# reference to the internal Postgres service URL automatically.
DATABASE_URL="postgresql://postgres:local@localhost:5432/daybeans"

# 32-byte base64 key — generate with: openssl rand -base64 32
APP_ENCRYPTION_KEY="REPLACE_WITH_32_BYTE_BASE64_KEY"

# Auth: 'none' | 'simple' | 'full'. Phase 1 uses 'none'. Phase 7 enables the others.
AUTH_MODE="none"

# Required when AUTH_MODE=simple or AUTH_MODE=full. Generate: openssl rand -base64 32
AUTH_SECRET=""

# Required when AUTH_MODE=simple. Generate: pnpm exec tsx scripts/hash-password.ts
SIMPLE_PASSWORD_HASH=""

# Required when AUTH_MODE=simple. Identifies the bootstrap admin — the user
# with this email gets isAdmin=true and is seeded with SIMPLE_PASSWORD_HASH
# on first boot. Admin can create additional users via /admin.
ADMIN_EMAIL=""

# Phase 10 scheduler. Required on railway.
CRON_SECRET=""

# S0-T09 — Dual-run cost-graduation policy.
# 'always'       — Stage 0 (default). Pre-brew runs for all active users.
# 'tiered'       — Stage 1. Paid + streak users + flaky regions only.
# 'reactive'     — Stage 2. Only when a provider's recent error rate > 1%.
# 'smart-resume' — Stage 3. Skip when journal themes haven't shifted.
PREBREW_POLICY="always"

# Optional: LLM .env override.
# When LLM_DEFAULT is set, the matching API key REPLACES any per-user
# LlmCredential row. Use this for self-hosted single-user installs to
# skip the Settings UI entirely.
#   LLM_DEFAULT  ::= "OpenAI" | "Anthropic" | "LM Studio"  (case-insensitive)
#   MODEL_DEFAULT::= e.g. "gpt-4o", "claude-sonnet-4-5"
LLM_DEFAULT=""
MODEL_DEFAULT=""

OPENAI_API_KEY=""
ANTHROPIC_API_KEY=""

# Optional: override LM Studio URL (default http://localhost:1234/v1)
LMSTUDIO_BASE_URL=""

# Optional: GitHub personal access token. Raises GitHub Search rate limit
# from 10/min unauthenticated to 30/min. No scopes needed — read-only.
# Generate at https://github.com/settings/tokens (classic, no scopes)
# or https://github.com/settings/personal-access-tokens (fine-grained).
GITHUB_TOKEN=""

# S5-T05 — Voucher emails (Resend).
# When unset, the email client logs the would-be email to console and returns
# a fake messageId so the claim flow keeps working in development without an
# API key. Set this in production to actually deliver mail.
RESEND_API_KEY=
EMAIL_FROM="DayBeans <hello@daybeans.com>"
